<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragEnlaces">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <Button
            android:id="@+id/enlacePXGNSSCOM"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PXGNSS.COM" />

        <Button
            android:id="@+id/enlaceCONV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONVERTIDOR" />

        <Button
            android:id="@+id/enlacePROMEDIO"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Promedio/Estadísticas"
            />
        <Button
            android:id="@+id/enlaceMENSAJES"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mensajes"
            />
        <Button
            android:id="@+id/enlaceSEÑALES"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Señales"
            />
        <Button
            android:id="@+id/enlaceHAS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activar HAS"
            />
        <Button
            android:id="@+id/enlaceADDIP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar por IP"
            />
        <EditText
            android:id="@+id/editTextMensajes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="start|top"
            android:inputType="none"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>